# LLM provider: "ollama" for local dev, "groq" for hosted deployment
LLM_PROVIDER=ollama

# Groq (only needed when LLM_PROVIDER=groq) — get a free key at console.groq.com
GROQ_API_KEY=

# Langfuse observability — keys from your Langfuse project settings
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Frontend build + CORS (set to your server's IP when deploying)
VITE_API_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000
